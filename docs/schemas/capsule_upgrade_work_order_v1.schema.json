{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://project-atlas.local/schemas/capsule_upgrade_work_order_v1.schema.json",
  "title": "Capsule Upgrade Work Order v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "orderId",
    "generatedAt",
    "generatedBy",
    "project",
    "protocol",
    "detection",
    "adoption",
    "policy",
    "upgradePlan",
    "atlasActions",
    "forbiddenActions"
  ],
  "properties": {
    "schema": {
      "const": "capsule.upgrade_work_order.v1"
    },
    "orderId": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "generatedBy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "system",
        "mode"
      ],
      "properties": {
        "system": {
          "const": "project_atlas"
        },
        "mode": {
          "enum": [
            "catalog_diff",
            "operator_requested",
            "scheduled_review"
          ]
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "atlasProjectId",
        "atlasTitle",
        "capsuleProjectId",
        "repoRoot",
        "visibility"
      ],
      "properties": {
        "atlasProjectId": {
          "type": "string"
        },
        "atlasTitle": {
          "type": "string"
        },
        "capsuleProjectId": {
          "type": [
            "string",
            "null"
          ]
        },
        "repoRoot": {
          "type": [
            "string",
            "null"
          ]
        },
        "visibility": {
          "enum": [
            "public",
            "private",
            "internal",
            "unknown"
          ]
        }
      }
    },
    "protocol": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocolId",
        "name",
        "currentVersion",
        "targetVersion",
        "catalogDigest",
        "catalogSource"
      ],
      "properties": {
        "protocolId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "currentVersion": {
          "type": [
            "string",
            "null"
          ]
        },
        "targetVersion": {
          "type": "string"
        },
        "catalogDigest": {
          "type": "string"
        },
        "catalogSource": {
          "type": "string"
        }
      }
    },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "observedAt",
        "evidence"
      ],
      "properties": {
        "status": {
          "enum": [
            "current",
            "missing_metadata",
            "outdated",
            "unsupported",
            "pending_adoption",
            "not_applicable"
          ]
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "kind",
              "ref",
              "summary"
            ],
            "properties": {
              "kind": {
                "enum": [
                  "capsule_manifest",
                  "ops_capsule",
                  "protocol_catalog",
                  "atlas_record",
                  "operator_note"
                ]
              },
              "ref": {
                "type": "string"
              },
              "summary": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "adoption": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "recordedVersion",
        "targetVersion",
        "recordedAt",
        "evidenceRef"
      ],
      "properties": {
        "status": {
          "enum": [
            "not_detected",
            "current",
            "upgrade_order_generated",
            "operator_approved",
            "in_progress",
            "adopted",
            "blocked",
            "deferred",
            "not_applicable"
          ]
        },
        "recordedVersion": {
          "type": [
            "string",
            "null"
          ]
        },
        "targetVersion": {
          "type": "string"
        },
        "recordedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "evidenceRef": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "writePolicy",
        "operatorApprovalRequired",
        "multiRepoMutationAllowed",
        "allowedMutationScopes"
      ],
      "properties": {
        "writePolicy": {
          "enum": [
            "stage_only_until_user_approved",
            "record_only",
            "manual_target_repo_change"
          ]
        },
        "operatorApprovalRequired": {
          "const": true
        },
        "multiRepoMutationAllowed": {
          "const": false
        },
        "allowedMutationScopes": {
          "type": "array",
          "items": {
            "enum": [
              "atlas_record",
              "atlas_review_draft",
              "atlas_queue_item",
              "target_project_docs",
              "target_project_schema",
              "target_project_tests",
              "target_project_capsule_metadata"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "upgradePlan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "steps",
        "validation",
        "rollback"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "title",
              "owner",
              "mutationScope"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "owner": {
                "enum": [
                  "operator",
                  "atlas",
                  "target_project_agent",
                  "capsule"
                ]
              },
              "mutationScope": {
                "enum": [
                  "atlas_record",
                  "target_project_docs",
                  "target_project_schema",
                  "target_project_tests",
                  "target_project_capsule_metadata",
                  "none"
                ]
              }
            }
          }
        },
        "validation": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rollback": {
          "type": "string"
        }
      }
    },
    "atlasActions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "createsQueueItem",
        "createsReviewDraft",
        "recordsAdoptionStatus"
      ],
      "properties": {
        "createsQueueItem": {
          "type": "boolean"
        },
        "createsReviewDraft": {
          "type": "boolean"
        },
        "recordsAdoptionStatus": {
          "type": "boolean"
        }
      }
    },
    "forbiddenActions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "mutate_other_repository_without_operator_approval",
          "push_or_publish_without_operator_approval",
          "mark_adopted_without_evidence",
          "run_unapproved_target_project_commands",
          "rewrite_capsule_catalog_from_atlas_detection"
        ]
      },
      "uniqueItems": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
