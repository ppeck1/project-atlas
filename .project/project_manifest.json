{
  "schema_version": "0.2",
  "project_id": "project-atlas",
  "display_name": "Project Atlas",
  "root": ".",
  "repo_kind": "software",
  "visibility": "public",
  "profiles": [
    "public_repo",
    "software_project"
  ],
  "canonical_docs": {
    "readme": "README.md",
    "handoff": "docs/HANDOFF.md",
    "variable_matrix": "docs/VARIABLE_MATRIX.md",
    "operations": "HANDOFF.md",
    "architecture": "VARIABLE_MAP.md"
  },
  "validation": {
    "required": [
      "flutter analyze",
      "flutter test"
    ],
    "focused": [
      "dart run build_runner build",
      "flutter test test\\schema_media_test.dart test\\local_operations_registry_test.dart test\\document_import_test.dart test\\smoke_test.dart test\\project_summary_models_test.dart test\\ollama_service_test.dart",
      "flutter test test\\local_operations_scanner_test.dart test\\local_git_visibility_service_test.dart test\\github_remote_metadata_service_test.dart test\\atlas_agent_service_test.dart test\\atlas_mcp_adapter_test.dart test\\project_update_attribution_test.dart test\\ollama_service_test.dart"
    ],
    "smoke": [
      "flutter build windows --release"
    ],
    "manual": [
      "flutter run -d windows",
      "README screenshot visual check when screenshots change"
    ]
  },
  "protected_paths": [
    ".github/",
    "LICENSE",
    "SECURITY.md",
    "README.md",
    "HANDOFF.md",
    "VARIABLE_MAP.md",
    "docs/HANDOFF.md",
    "docs/VARIABLE_MATRIX.md",
    "pubspec.yaml",
    "pubspec.lock",
    "windows/runner/resources/app_icon.ico"
  ],
  "generated_paths": [
    ".dart_tool/",
    "build/",
    "dist/",
    ".demo_appdata/",
    ".atlas_backups/",
    ".claude/",
    "lib/db/app_db.g.dart",
    ".flutter-plugins-dependencies",
    "atlas-windows-*.zip",
    ".project/runs/",
    ".project/atlas_outbox/",
    ".project/boh_outbox/",
    ".project/verification/"
  ],
  "secrets_policy": "names-only",
  "atlas_sync": {
    "enabled": true,
    "mode": "outbox",
    "project_key": "project-atlas"
  },
  "boh_sync": {
    "enabled": true,
    "mode": "outbox",
    "authority": "evidence-only",
    "project_key": "project-atlas"
  },
  "git_policy": {
    "require_git": true,
    "commit_after_signable_run": true,
    "push_policy": "manual",
    "allow_dirty_unrelated": false
  }
}
